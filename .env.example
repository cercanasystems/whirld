# Whirld environment configuration template.
# Copy to `.env` for local development. Never commit `.env`.

# Override the default cache/home directory (default: ~/.whirld).
# WHIRLD_HOME=/path/to/whirld/home

# Application log level: DEBUG | INFO | WARNING | ERROR (default: INFO to stderr).
# WHIRLD_LOG_LEVEL=INFO

# Bearer token for gated STAC endpoints (e.g. Microsoft Planetary Computer).
# Passed as `Authorization: Bearer <token>`; never logged, never written to disk.
# WHIRLD_STAC_TOKEN=
